APP_ENV=development
SECRET_KEY=change-this-to-a-long-random-value

# Enable authentication by setting AUTH_REQUIRED=true and one password option.
AUTH_REQUIRED=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# ADMIN_PASSWORD_HASH can be generated with:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"
ADMIN_PASSWORD_HASH=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=20

PDF_STORAGE_DIR=uploaded_pdfs
DB_PATH=pdfokuyucu_app_v2.sqlite
SQLITE_JOURNAL_MODE=WAL
MAX_PDF_BYTES=52428800
AI_SYNC_MAX_PAGES=80
AI_SYNC_MAX_CHARS=120000
ENABLE_OCR=false
VIRUS_SCAN_ENABLED=false
